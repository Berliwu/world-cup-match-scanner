# AI match narrative (optional for `match`; use --no-ai to skip)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Club CSV defaults (England Premier League 2020)
CLUB_LEAGUE=England
CLUB_DIVISION=1
CLUB_YEAR=2020

# Redis cache (optional — falls back to in-memory when unavailable)
REDIS_URL=redis://localhost:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_DB=0

# Set to false to disable Redis and use in-memory cache only
REDIS_ENABLED=true

# Cache key prefix and default TTL (seconds)
REDIS_KEY_PREFIX=wc2026-scanner:
REDIS_CACHE_TTL_SEC=3600
